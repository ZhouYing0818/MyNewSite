---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date) - new Date(a.data.date)
);
---

<BaseLayout title="博客 | Boundless" activeNav="blog">

  <!-- Page Header -->
  <section style="padding-top: var(--zy-space-16); padding-bottom: var(--zy-space-12);">
    <h2 style="font-family: var(--zy-font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 600; line-height: 1.2; letter-spacing: -0.015em; color: var(--zy-text-primary); text-wrap: balance; word-break: keep-all; overflow-wrap: break-word;" data-zh="博客" data-en="Blog">博客</h2>
    <p style="margin-top: var(--zy-space-3); font-size: var(--zy-text-base); color: var(--zy-text-muted); max-width: 36ch;" data-zh="记录思考与发现" data-en="Recording thoughts and discoveries">记录思考与发现</p>
  </section>

  <!-- Blog List -->
  <section style="padding-bottom: var(--zy-space-20);">
    <div style="display: flex; flex-direction: column; gap: var(--zy-space-4);">
      {allPosts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-entry" style="display: flex; align-items: flex-start; gap: var(--zy-space-5); border-radius: var(--zy-radius-md); padding: var(--zy-space-5); text-decoration: none; background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border); transition: background-color 160ms cubic-bezier(0.2, 0.8, 0.2, 1), border-color 160ms cubic-bezier(0.2, 0.8, 0.2, 1);">
          <time style="flex-shrink: 0; font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); white-space: nowrap; font-family: var(--zy-font-mono); color: var(--zy-text-muted); min-width: 72px; padding-top: 2px;">{post.data.date}</time>
          <div style="display: flex; flex-direction: column; gap: var(--zy-space-1); min-width: 0; flex: 1;">
            <h3 style="font-size: var(--zy-text-base); font-weight: var(--zy-font-semibold); font-family: var(--zy-font-body); color: var(--zy-text-primary); letter-spacing: -0.01em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin: 0;">{post.data.title}</h3>
            {post.data.description && (
              <p style="font-size: var(--zy-text-sm); margin: 0; color: var(--zy-text-secondary); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{post.data.description}</p>
            )}
            {post.data.tags && post.data.tags.length > 0 && (
              <div style="display: flex; flex-wrap: wrap; gap: var(--zy-space-2); margin-top: var(--zy-space-1);">
                {post.data.tags.map((tag: string) => (
                  <span style="display: inline-block; padding: 2px 8px; border-radius: var(--zy-radius-full); font-size: var(--zy-text-xs); font-weight: var(--zy-font-medium); font-family: var(--zy-font-body); background-color: var(--zy-color-primary-subtle); color: var(--zy-color-primary-light);">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {allPosts.length === 0 && (
      <div style="text-align: center; padding: var(--zy-space-16) 0;">
        <p style="font-size: var(--zy-text-sm); color: var(--zy-text-muted); font-style: italic;" data-zh="暂无博客文章，敬请期待..." data-en="No blog posts yet, stay tuned...">暂无博客文章，敬请期待...</p>
      </div>
    )}
  </section>

</BaseLayout>

<style>
  .blog-entry:hover {
    background-color: var(--zy-bg-surface-hover);
    border-color: rgba(79, 109, 142, 0.2);
  }
</style>
