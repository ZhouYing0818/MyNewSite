---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="里程碑 | Boundless" activeNav="milestones">

  <!-- Page Heading -->
  <section style="padding-top: var(--zy-space-16); padding-bottom: var(--zy-space-12);">
    <h2 style="font-family: var(--zy-font-display); font-size: clamp(28px, 4vw, 40px); font-weight: 600; letter-spacing: var(--zy-tracking-tight); color: var(--zy-text-primary); text-wrap: balance; word-break: keep-all; overflow-wrap: break-word;" data-zh="里程碑" data-en="Milestones">里程碑</h2>
    <p style="margin-top: var(--zy-space-3); font-size: var(--zy-text-base); color: var(--zy-text-muted); max-width: 36ch;" data-zh="记录成长中的每一个重要时刻" data-en="Recording every important moment of growth">记录成长中的每一个重要时刻</p>
  </section>

  <!-- Timeline -->
  <section style="padding-bottom: var(--zy-space-20);">
    <div style="position: relative;">
      <!-- Central timeline line -->
      <div style="position: absolute; left: 16px; top: 0; bottom: 0; width: 1px; background-color: var(--zy-border);"></div>

      <!-- Milestone 1: 2012.09 - LEFT -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2012.09</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="考入湖南农业大学生物工程专业" data-en="Entered Hunan Agricultural University for Bioengineering">考入湖南农业大学生物工程专业</p>
          </div>
        </div>
      </div>

      <!-- Milestone 2: 2016.09 - RIGHT -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2016.09</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="进入复旦大学攻读神经生物学硕士，研究VIP中间神经元分类" data-en="Started MSc in Neurobiology at Fudan University, researching VIP interneuron classification">进入复旦大学攻读神经生物学硕士，研究VIP中间神经元分类</p>
          </div>
        </div>
      </div>

      <!-- Milestone 3: 2017 - LEFT -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2017</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="发表第一篇论文：断奶后隔离对小鼠焦虑抑郁样行为的影响 (Experimental Brain Research)" data-en="Published first paper: Effect of post-weaning isolation on anxiety/depressive-like behaviors (Experimental Brain Research)">发表第一篇论文：断奶后隔离对小鼠焦虑抑郁样行为的影响 (Experimental Brain Research)</p>
          </div>
        </div>
      </div>

      <!-- Milestone 4: 2018.07 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2018.07</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="参加第11届FENS神经科学论坛（柏林），并在中国细胞生物学学会全国科普活动中担任志愿者" data-en="Attended the 11th FENS Forum of Neuroscience (Berlin), volunteered at national science popularization event">参加第11届FENS神经科学论坛（柏林），并在中国细胞生物学学会全国科普活动中担任志愿者</p>
          </div>
        </div>
      </div>

      <!-- Milestone 5: 2020.01 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2020.01</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="复旦大学硕士论文答辩获92.32/100分" data-en="Completed Fudan University master's thesis defense with 92.32/100">复旦大学硕士论文答辩获92.32/100分</p>
          </div>
        </div>
      </div>

      <!-- Milestone 6: 2020.05 - 2022.06 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2020.05 - 2022.06</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="以聚道科技（GeneDock）身份派驻上海交通大学医学院附属新华医院临床遗传中心，负责临床WES/WGS数据分析与遗传变异解读项目" data-en="Seconded to Clinical Genetics Center, Xinhua Hospital (SJTU) via GeneDock, leading clinical WES/WGS data analysis and genetic variant interpretation projects">以聚道科技（GeneDock）身份派驻上海交通大学医学院附属新华医院临床遗传中心，负责临床WES/WGS数据分析与遗传变异解读项目</p>
          </div>
        </div>
      </div>

      <!-- Milestone 7: 2022.08 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2022.08</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="VIP中间神经元分类论文发表于 Cerebral Cortex" data-en="VIP interneuron classification paper published in Cerebral Cortex">VIP中间神经元分类论文发表于 Cerebral Cortex</p>
          </div>
        </div>
      </div>

      <!-- Milestone 8: 2022.09 - 2025.06 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2022.09 - 2025.06</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="进入哈尔滨医科大学攻读生物信息学硕士（GPA 3.8），研究GBM与神经发育轨迹比较" data-en="Started MSc in Bioinformatics at Harbin Medical University (GPA 3.8), studying GBM and neurodevelopmental trajectories">进入哈尔滨医科大学攻读生物信息学硕士（GPA 3.8），研究GBM与神经发育轨迹比较</p>
          </div>
        </div>
      </div>

      <!-- Milestone 9: 2022.10 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2022.10</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="变异优先级排序论文发表于 Clinical Genetics（共同第一作者）" data-en="Variant prioritization paper published in Clinical Genetics (first co-author)">变异优先级排序论文发表于 Clinical Genetics（共同第一作者）</p>
          </div>
        </div>
      </div>

      <!-- Milestone 10: 2023.01 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2023.01</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="开始GBM与神经发育轨迹系统比较研究项目" data-en="Started systematic comparison of GBM and neurodevelopmental trajectories project">开始GBM与神经发育轨迹系统比较研究项目</p>
          </div>
        </div>
      </div>

      <!-- Milestone 11: 2024.03 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2024.03</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="参加第二届国际单细胞与空间组学大会（TICSSO-2，深圳）" data-en="Attended the 2nd International Conference on Single-cell and Spatial Omics (TICSSO-2, Shenzhen)">参加第二届国际单细胞与空间组学大会（TICSSO-2，深圳）</p>
          </div>
        </div>
      </div>

      <!-- Milestone 12: 2025.07 -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2025.07</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="作为自由职业生物信息工程师，开展骨关节炎生物标志物与NAFLD配体-受体互作研究（2025.07-2026.11）" data-en="Started as freelance bioinformatician on OA biomarker and NAFLD projects (Jul 2025 - Nov 2026)">作为自由职业生物信息工程师，开展骨关节炎生物标志物与NAFLD配体-受体互作研究（2025.07-2026.11）</p>
          </div>
        </div>
      </div>

      <!-- Milestone 13: 2025.12 - Present -->
      <div class="fade-in milestone-item" style="position: relative; margin-bottom: var(--zy-space-12);">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2025.12.1 - 至今</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="加入爱彼爱科（丽水）医学检验实验室/浙大丽水研究中心甲基化实验室，担任生信工程师。跨国同加拿大 Moshe Szyf 教授团队合作，将学术研究向医学和健康管理转化。与丽水市第二人民医院合作青少年抑郁甲基化诊断研究。" data-en="Joined Aibeiaike (Lishui) / ZJU Lishui Methylation Lab as Bioinformatics Engineer. Collaborating with Prof. Moshe Szyf (Canada) to translate research into medicine. Partnering with Lishui Second People's Hospital on adolescent depression methylation diagnosis.">加入爱彼爱科（丽水）医学检验实验室/浙大丽水研究中心甲基化实验室，担任生信工程师。跨国同加拿大 Moshe Szyf 教授团队合作，将学术研究向医学和健康管理转化。与丽水市第二人民医院合作青少年抑郁甲基化诊断研究。</p>
          </div>
        </div>
      </div>

      <!-- Milestone 14: 2026.06 -->
      <div class="fade-in milestone-item" style="position: relative;">
        <div style="position: absolute; left: 16px; top: 0; width: 12px; height: 12px; border-radius: var(--zy-radius-full); background-color: var(--zy-color-accent); transform: translateX(-50%); z-index: 10;"></div>
        <div style="padding-left: var(--zy-space-10);">
          <div class="ms-card" style="display: inline-block; border-radius: var(--zy-radius-lg); padding: var(--zy-space-5); background-color: var(--zy-bg-surface); border: 1px solid var(--zy-border);">
            <p style="font-size: var(--zy-text-sm); font-weight: var(--zy-font-medium); margin-bottom: var(--zy-space-2); white-space: nowrap; color: var(--zy-color-accent); font-family: var(--zy-font-mono);">2026.06</p>
            <p style="font-size: var(--zy-text-sm); line-height: 1.6; color: var(--zy-text-secondary);" data-zh="通过临床医学检验师（初级）考试，成绩已出，待发证" data-en="Passed Clinical Medical Laboratory Technician (Primary) Exam, results received, certificate pending">通过临床医学检验师（初级）考试，成绩已出，待发证</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .ms-card {
    transition: background-color var(--zy-transition-base);
  }
  .ms-card:hover {
    background-color: var(--zy-bg-surface-hover);
  }

  @media (min-width: 768px) {
    .milestone-item:nth-child(odd) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
    }
    .milestone-item:nth-child(even) {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
    }
  }
</style>
