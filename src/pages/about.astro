---

<BaseLayout title="关于我 | Boundless" activeNav="about">

  <!-- Contact Bar -->
  <div style="display: flex; flex-wrap: wrap; align-items: center; gap: var(--zy-space-6); padding: var(--zy-space-5) 0; border-bottom: 1px solid var(--zy-border);">
    <a href="mailto:zhouying_ch@qq.com" style="display: flex; align-items: center; gap: var(--zy-space-2); font-size: var(--zy-text-sm); text-decoration: none; color: var(--zy-text-secondary); transition: color var(--zy-transition-base);" aria-label="Email">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--zy-color-primary-light);"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      <span>zhouying_ch@qq.com</span>
