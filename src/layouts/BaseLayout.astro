---
interface Props {
  title: string;
  activeNav: string;
}
const { title, activeNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Zhou Ying (周莹) - Academic personal portfolio | Bioinformatics, Computational Biology, Life Sciences" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon (placeholder) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Global Styles -->
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>

  <!-- ======================================== -->
  <!-- GLOBAL BACKGROUND SLIDESHOW              -->
  <!-- ======================================== -->
  <div class="bg-slideshow" aria-hidden="true">
    <div class="bg-slide active" style="background-image: url('/images/hero-abstract.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-changbaishan.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-japan.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-shengsi.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-berlin.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-daweishan.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-hangzhou.jpg');"></div>
    <div class="bg-slide" style="background-image: url('/images/gallery-typhoon.jpg');"></div>
    <div class="bg-overlay"></div>
  </div>

  <!-- ======================================== -->
  <!-- HEADER / NAVIGATION                      -->
  <!-- ======================================== -->
  <header class="site-header">
    <nav class="site-nav">

      <!-- Left: Logo / Site Name -->
      <a href="/" class="nav-logo">
        <div class="nav-logo-circle">
          <span>ZY</span>
        </div>
        <span class="nav-logo-text">Boundless</span>
      </a>

      <!-- Right: Navigation Links -->
      <ul class="nav-links" id="navLinks">
        <li>
          <a
            href="/"
            class:list={[activeNav === 'home' && 'active']}
            data-zh="首页"
            data-en="Home"
          >首页</a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[activeNav === 'about' && 'active']}
            data-zh="关于我"
            data-en="About"
          >关于我</a>
        </li>
        <li>
          <a
            href="/projects"
            class:list={[activeNav === 'projects' && 'active']}
            data-zh="项目经历"
            data-en="Projects"
          >项目经历</a>
        </li>
        <li>
          <a
            href="/milestones"
            class:list={[activeNav === 'milestones' && 'active']}
            data-zh="里程碑"
            data-en="Milestones"
          >里程碑</a>
        </li>
        <li>
          <a
            href="/travel"
            class:list={[activeNav === 'travel' && 'active']}
            data-zh="旅行足迹"
            data-en="Travel"
          >旅行足迹</a>
        </li>
        <li>
          <a
            href="/blog"
            class:list={[activeNav === 'blog' && 'active']}
            data-zh="博客"
            data-en="Blog"
          >博客</a>
        </li>
        <li>
          <button class="nav-lang-toggle" data-lang-toggle>Eng</button>
        </li>
      </ul>

      <!-- Mobile hamburger toggle -->
      <button class="nav-mobile-toggle" id="mobileMenuToggle" aria-label="Toggle navigation">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
      </button>

    </nav>
  </header>

  <!-- ======================================== -->
  <!-- MAIN CONTENT                              -->
  <!-- ======================================== -->
  <main class="zy-container" style="flex: 1; position: relative; z-index: 1;">
    <slot />
  </main>

  <!-- ======================================== -->
  <!-- FOOTER                                    -->
  <!-- ======================================== -->
  <footer class="site-footer">
    <div class="site-footer-inner">

      <!-- Left: Copyright -->
      <p>&copy; 2024 Zhou Ying</p>

      <!-- Right: Social / Contact links -->
      <ul class="footer-links">
        <li>
          <a href="https://github.com/ZhouYing0818" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            <span class="footer-link-text" data-zh="GitHub" data-en="GitHub">GitHub</span>
          </a>
        </li>
        <li>
          <a href="mailto:zhouying_ch@qq.com">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="footer-link-text" data-zh="邮箱" data-en="Email">邮箱</span>
          </a>
        </li>
        <li>
          <a href="https://scholar.google.com" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            <span class="footer-link-text" data-zh="学术" data-en="Scholar">学术</span>
          </a>
        </li>
        <li>
          <a href="https://www.researchgate.net" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="footer-link-text" data-zh="ResearchGate" data-en="ResearchGate">ResearchGate</span>
          </a>
        </li>
      </ul>

    </div>
  </footer>

  <!-- ======================================== -->
  <!-- SCRIPTS                                   -->
  <!-- ======================================== -->
  <script>
    // --- Language Toggle ---
    function toggleLang() {
      const html = document.documentElement;
      const isZh = html.lang === 'zh-CN';
      html.lang = isZh ? 'en' : 'zh-CN';

      document.querySelectorAll('[data-zh][data-en]').forEach((el) => {
        const text = el.getAttribute(isZh ? 'data-en' : 'data-zh');
        if (text) el.textContent = text;
      });

      const langBtn = document.querySelector('[data-lang-toggle]') as HTMLButtonElement | null;
      if (langBtn) langBtn.textContent = isZh ? '中' : 'Eng';
    }

    document.querySelectorAll('[data-lang-toggle]').forEach((btn) => {
      btn.addEventListener('click', toggleLang);
    });

    // --- Mobile Menu Toggle ---
    const mobileToggle = document.getElementById('mobileMenuToggle');
    const navLinks = document.getElementById('navLinks');

    if (mobileToggle && navLinks) {
      mobileToggle.addEventListener('click', () => {
        navLinks.classList.toggle('open');
      });
    }

    // --- Background Slideshow ---
    const slides = document.querySelectorAll('.bg-slide');
    if (slides.length > 1) {
      let current = 0;
      setInterval(() => {
        slides[current].classList.remove('active');
        current = (current + 1) % slides.length;
        slides[current].classList.add('active');
      }, 8000);
    }

    // --- Fade-in on scroll (Intersection Observer) ---
    const fadeEls = document.querySelectorAll('.fade-in');
    if (fadeEls.length > 0 && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      fadeEls.forEach((el) => observer.observe(el));
    }
  </script>

</body>
</html>
